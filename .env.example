# MongoDB Connection
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-min-32-characters
JWT_EXPIRES_IN=7d

# App URL (update for production)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Email Configuration (Gmail + Nodemailer)
GMAIL_USER=your-gmail@gmail.com
GMAIL_APP_PASSWORD=your-16-char-app-password

# Cron Job Secret
CRON_SECRET=your-cron-secret-key

# Node Environment
NODE_ENV=development

# Vercel Analytics
# Get access token from: https://vercel.com/account/tokens
VERCEL_ACCESS_TOKEN=your-vercel-access-token
# Optional: only needed if you're part of a team
VERCEL_TEAM_ID=your-team-id
# Get from Vercel project settings
VERCEL_PROJECT_ID=your-project-id

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# PostHog Analytics (get from posthog.com → Project Settings)
NEXT_PUBLIC_POSTHOG_KEY=phc_your_project_api_key
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# AI Suggestions on the dashboard (Groq — get from console.groq.com/keys)
GROK_API_KEY=gsk_your_groq_api_key
